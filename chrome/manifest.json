{
  "manifest_version": 3,
  "name": "Tab Dedup - 重复标签页检测",
  "version": "4.1.0",
  "description": "检测并关闭重复标签页，支持批量操作、预览和智能分组",
  "permissions": [
    "tabs",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Tab Dedup",
    "default_icon": {
      "48": "icons/icon-48.svg"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icons/icon-48.svg"
  }
}
